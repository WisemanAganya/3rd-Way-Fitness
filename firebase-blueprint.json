{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Represents a gym member and their profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "ageCategory": { "type": "string", "enum": ["child", "teenager", "adult"] },
        "progressionLevel": { "type": "string", "description": "Member rank or level" },
        "subscriptionId": { "type": "string", "description": "Reference to membership_plans" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "expired", "pending"] },
        "enrolledPrograms": { "type": "array", "description": "List of program IDs" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "ageCategory"]
    },
    "Program": {
      "title": "Program",
      "description": "Fitness programs offered like Bootcamps, House of Pain, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["gym", "bootcamp", "house_of_pain", "hike", "roadwork", "camping"] },
        "frequency": { "type": "string", "enum": ["weekly", "monthly", "per_session"] },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "price"]
    },
    "MembershipPlan": {
      "title": "Membership Plan",
      "description": "Standard membership tiers for different age groups.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "targetAge": { "type": "string", "enum": ["child", "teenager", "adult"] },
        "rates": {
          "type": "object",
          "properties": {
            "hourly": { "type": "number" },
            "weekly": { "type": "number" },
            "monthly": { "type": "number" },
            "per_session": { "type": "number" }
          }
        },
        "benefits": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "targetAge", "rates"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Session or program bookings made by members.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "programId": { "type": "string" },
        "bookingDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["confirmed", "attended", "cancelled"] },
        "pricePaid": { "type": "number" },
        "rateType": { "type": "string", "enum": ["hourly", "weekly", "monthly", "per_session"] }
      },
      "required": ["memberId", "programId", "bookingDate"]
    },
    "WorkoutPlan": {
      "title": "Workout Plan",
      "description": "AI-generated personalized workout routines.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "goal": { "type": "string" },
        "duration": { "type": "string" },
        "planContent": { "type": "string", "description": "Markdown content generated by AI" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "planContent"]
    },
    "SiteContent": {
      "title": "Site Content",
      "description": "CMS content for managing website sections.",
      "type": "object",
      "properties": {
        "section": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["section", "title"]
    },
    "Product": {
      "title": "Product",
      "description": "Merchandise like t-shirts and gym attire.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Merchandise orders and payments.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "items", "total", "status"]
    }
  },
  "firestore": {
    "/members/{memberId}": { "schema": "Member", "description": "User profiles" },
    "/programs/{programId}": { "schema": "Program", "description": "Available fitness programs" },
    "/membership_plans/{planId}": { "schema": "MembershipPlan", "description": "Standard pricing tiers" },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Session bookings" },
    "/workout_plans/{planId}": { "schema": "WorkoutPlan", "description": "Generated workout plans" },
    "/site_content/{contentId}": { "schema": "SiteContent", "description": "CMS data" },
    "/products/{productId}": { "schema": "Product", "description": "Merchandise items" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" }
  }
}
